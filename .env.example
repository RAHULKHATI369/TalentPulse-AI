# TalentPulse AI Environment Configurations
# Copy this file to .env and configure the parameters

# Google AI Studio API Key (Obtain from https://aistudio.google.com/)
GEMINI_API_KEY=AQ.Ab8RN6LJxGXfTG8NQrUZvLQ_Pr3hhTCcUf1aU3ojTOSFdEKrCw

# MariaDB / MySQL Configuration
# Inside Docker Compose, we configure db as the database host name
DATABASE_URL=mysql+pymysql://talentpulse_user:talentpulse_password@db:3306/talentpulse_db

# Local database URL fallback for running outside Docker (adjust host accordingly)
# DATABASE_URL=mysql+pymysql://talentpulse_user:talentpulse_password@localhost:3306/talentpulse_db

# FastAPI Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Hugging Face ml-intern Verification Hooks
ML_INTERN_HOOK_URL=http://localhost:8080/ml-intern/validate
